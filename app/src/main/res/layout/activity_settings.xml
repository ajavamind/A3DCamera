<?xml version="1.0" encoding="utf-8"?>
<!-- Settings screen for A3DCamera -->
<!-- Copyright 2025-2026 Andy Modla All Rights Reserved -->

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:fillViewport="true"
    android:paddingStart="100dp"
    android:paddingEnd="100dp"
    android:scrollbarStyle="outsideOverlay">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="#4FC3F7"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- ============================================================ -->
        <!-- SECTION 1: Application Mode                                  -->
        <!-- ============================================================ -->
        <!-- Camera Mode -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Camera Mode"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enable camera mode (performs a restart)"
            android:textColor="#9E9E9E"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <RadioGroup
            android:id="@+id/rg_camera_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">
<!--
            <RadioButton
                android:id="@+id/rb_basic_camera_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Basic Camera Mode"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:buttonTint="#4FC3F7"
                android:layout_marginBottom="4dp" />
-->
            <RadioButton
                android:id="@+id/rb_stereoscope_camera_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stereoscope Camera Mode"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:buttonTint="#4FC3F7"
                android:layout_marginBottom="4dp" />

            <RadioButton
                android:id="@+id/rb_photo_booth_camera_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Photo Booth Camera Mode"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:buttonTint="#4FC3F7"
                android:layout_marginBottom="4dp" />
        </RadioGroup>

        <!-- ============================================================ -->
        <!-- SECTION 2: Camera                                            -->
        <!-- ============================================================ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Camera"
            android:textColor="#4FC3F7"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Sound On -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shutter Sound"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enable/disable shutter sound"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/sw_sound_on"
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:thumbTint="@color/switch_thumb_selector"
                android:trackTint="@color/switch_track_selector" />
        </LinearLayout>


        <!-- Countdown Enable -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Countdown Enable"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enable countdown timer before shutter release"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/sw_count_down_enabled"
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:thumbTint="@color/switch_thumb_selector"
                android:trackTint="@color/switch_track_selector" />
        </LinearLayout>

        <!-- Countdown Timer -->
        <TextView
		android:id="@+id/tv_countdown_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Countdown Timer (seconds)"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seconds to count down before shutter release"
            android:textColor="#9E9E9E"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_countdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
			android:layout_marginBottom="12dp"
            android:value="3.0"
            android:valueFrom="0"
            android:valueTo="30"
            android:stepSize="1"
            app:labelBehavior="withinBounds"
            app:tickVisible="true"
            />

        <!-- Focus Distance Index (RadioGroup) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Focus Distance"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select camera focus distance preset"
            android:textColor="#9E9E9E"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <RadioGroup
            android:id="@+id/rg_focus_distance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <RadioButton
                android:id="@+id/rb_focus_hyperfocal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HyperFocal Focus Distance 1.7 m"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:buttonTint="#4FC3F7"
                android:layout_marginBottom="4dp" />

            <RadioButton
                android:id="@+id/rb_focus_photobooth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Photo Booth Focus Distance 550mm"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:buttonTint="#4FC3F7"
                android:layout_marginBottom="4dp" />

            <RadioButton
                android:id="@+id/rb_focus_macro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Macro Focus Distance 100mm"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:buttonTint="#4FC3F7"
                android:layout_marginBottom="4dp" />
            <!--
            <RadioButton
                android:id="@+id/rb_focus_auto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto Focus Distance"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:buttonTint="#4FC3F7"
                android:layout_marginBottom="4dp" />
				-->
        </RadioGroup>

        <!-- Exposure Metering Index (RadioGroup) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Exposure Metering"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select camera exposure metering mode"
            android:textColor="#9E9E9E"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <RadioGroup
            android:id="@+id/rg_exposure_metering"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <RadioButton
                android:id="@+id/rb_exposure_frame_average"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Frame Average (normal)"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:buttonTint="#4FC3F7"
                android:layout_marginBottom="4dp" />

            <RadioButton
                android:id="@+id/rb_exposure_center_weighted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Center Weighted"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:buttonTint="#4FC3F7"
                android:layout_marginBottom="4dp" />

            <RadioButton
                android:id="@+id/rb_exposure_spot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spot Metering"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:buttonTint="#4FC3F7"
                android:layout_marginBottom="4dp" />
        </RadioGroup>

        <!-- Save LR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Save LR"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Override cameraMode to save Left/Right image files"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/sw_save_lr"
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:thumbTint="@color/switch_thumb_selector"
                android:trackTint="@color/switch_track_selector" />
        </LinearLayout>

        <!-- Save Anaglyph -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Save Anaglyph"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Override cameraMode to save Anaglyph image files"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/sw_save_anaglyph"
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:thumbTint="@color/switch_thumb_selector"
                android:trackTint="@color/switch_track_selector" />
        </LinearLayout>

        <!-- ============================================================ -->
        <!-- SECTION 3: Network                                           -->
        <!-- ============================================================ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Broadcast Network"
            android:textColor="#4FC3F7"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

		
        <!-- Broadcast Transmit/Receive Port (read-only) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Broadcast Port"
                    android:textColor="#E0E0E0"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Network port for broadcast messages (read-only)"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_receiver_port"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8000"
                android:textColor="#4FC3F7"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Broadcast Control Enable -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Broadcast Enable"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enable Wi-Fi broadcast controller for either transmit or receive (performs a restart)"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/sw_udp_control_enabled"
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:thumbTint="@color/switch_thumb_selector"
                android:trackTint="@color/switch_track_selector" />
        </LinearLayout>

        <!-- Broadcast Transmit -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Broadcast Mode"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Receive (off - default) or Transmit (on) (performs a restart)"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/sw_udp_transmit"
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:thumbTint="@color/switch_thumb_selector"
                android:trackTint="@color/switch_track_selector" />
        </LinearLayout>
		
		
        <!-- ============================================================ -->
        <!-- SECTION 4: Stereo Alignment                                  -->
        <!-- ============================================================ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stereo Window Alignment"
            android:textColor="#4FC3F7"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Parallax Offset -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Parallax Offset"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Left/right horizontal offset for stereo window placement (pixels)"
            android:textColor="#9E9E9E"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <SeekBar
                android:id="@+id/seek_parallax"
                android:layout_width="0dp"
                android:layout_height="24dp"
				android:minHeight="24dp"
				android:maxHeight="24dp"
                android:layout_weight="1"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:thumbTint="#4FC3F7"
                android:progressTint="#4FC3F7"
                android:secondaryProgressTint="#1A4FC3F7" />

            <TextView
                android:id="@+id/tv_parallax_value"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="end"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Vertical Offset -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vertical Offset"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Left/right vertical offset for camera correction (pixels)"
            android:textColor="#9E9E9E"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <SeekBar
                android:id="@+id/seek_vertical"
                android:layout_width="0dp"
                android:layout_height="24dp"
				android:minHeight="24dp"
				android:maxHeight="24dp"
                android:layout_weight="1"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:thumbTint="#4FC3F7"
                android:progressTint="#4FC3F7"
                android:secondaryProgressTint="#1A4FC3F7" />

            <TextView
                android:id="@+id/tv_vertical_value"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="end"
                android:layout_marginStart="8dp" />
        </LinearLayout>
		
		<!-- ============================================================ -->
        <!-- SECTION 5: Anaglyph Options                                   -->
        <!-- ============================================================ -->
		
        <LinearLayout
            android:id="@+id/layout_conditional_stereoscope"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <!-- Blank Screen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blank Screen"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cover active display with black"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/sw_blank_screen"
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:thumbTint="@color/switch_thumb_selector"
                android:trackTint="@color/switch_track_selector" />
        </LinearLayout>


        </LinearLayout>
        <!-- ============================================================ -->
        <!-- SECTION 6: Photo Booth Options                                   -->
        <!-- ============================================================ -->
		
        <LinearLayout
            android:id="@+id/layout_conditional_photobooth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

			
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Photo Booth Display Options"
            android:textColor="#4FC3F7"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Mirror -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mirror"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mirror image in photo booth mode"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/sw_mirror"
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:thumbTint="@color/switch_thumb_selector"
                android:trackTint="@color/switch_track_selector" />
        </LinearLayout>

        <!-- Auto Review -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto Review"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stay in review mode after capture until booth operator resumes live video"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/sw_auto_review"
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:thumbTint="@color/switch_thumb_selector"
                android:trackTint="@color/switch_track_selector" />
        </LinearLayout>

        <!-- AI Edit -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Edit Mode"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Launch AI application to edit captured photo"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/sw_ai_edit"
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:thumbTint="@color/switch_thumb_selector"
                android:trackTint="@color/switch_track_selector" />
        </LinearLayout>

        <!-- ============================================================ -->
        <!-- SECTION 7: Photo Booth Labels                                -->
        <!-- ============================================================ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Photo Booth Labels"
            android:textColor="#4FC3F7"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Title 1 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Title Line 1"
            android:textColor="#E0E0E0"
            android:textSize="13sp"
            android:layout_marginBottom="2dp" />

        <EditText
            android:id="@+id/et_title_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 3D Photo Booth"
            android:inputType="text"
            android:background="@android:drawable/edit_text"
            android:textColor="#000000"
            android:textColorHint="#888888"
            android:padding="8dp"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <!-- Title 2 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Title Line 2"
            android:textColor="#E0E0E0"
            android:textSize="13sp"
            android:layout_marginBottom="2dp" />

        <EditText
            android:id="@+id/et_title_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. Philadelphia Maker Faire"
            android:inputType="text"
            android:background="@android:drawable/edit_text"
            android:textColor="#000000"
            android:textColorHint="#888888"
            android:padding="8dp"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <!-- Instruction 1 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Instruction Line 1"
            android:textColor="#E0E0E0"
            android:textSize="13sp"
            android:layout_marginBottom="2dp" />

        <EditText
            android:id="@+id/et_instruction_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. Look at Camera"
            android:inputType="text"
            android:background="@android:drawable/edit_text"
            android:textColor="#000000"
            android:textColorHint="#888888"
            android:padding="8dp"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <!-- Instruction 2 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Instruction Line 2"
            android:textColor="#E0E0E0"
            android:textSize="13sp"
            android:layout_marginBottom="2dp" />

        <EditText
            android:id="@+id/et_instruction_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. additional text"
            android:inputType="text"
            android:background="@android:drawable/edit_text"
            android:textColor="#000000"
            android:textColorHint="#888888"
            android:padding="8dp"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />



        <!-- ============================================================ -->
        <!-- Photo Booth Print Output                                            -->
        <!-- ============================================================ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Photo Booth Print Output"
            android:textColor="#4FC3F7"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- SBS Crop Print -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SBS Crop Print"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Center-crop SBS photo to fit 6x4 printer paper"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/sw_sbs_crop_print"
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:thumbTint="@color/switch_thumb_selector"
                android:trackTint="@color/switch_track_selector" />
        </LinearLayout>
        </LinearLayout>

        <!-- Spacer at bottom -->
        <View
		    android:background="#8A8ACA"
            android:layout_width="match_parent"
            android:layout_height="16dp" />

    </LinearLayout>

</ScrollView>
